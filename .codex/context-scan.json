{
  "lastUpdated": "2026-03-27",
  "project": {
    "name": "ClipMate",
    "category": "macOS clipboard manager",
    "platform": ["macOS"],
    "stack": {
      "desktop": "Electron 33",
      "frontend": "Vue 3",
      "build": "electron-vite",
      "database": "better-sqlite3 / SQLite",
      "packaging": "electron-builder"
    }
  },
  "entrypoints": {
    "main": "src/main/index.ts",
    "preload": "src/preload/index.ts",
    "renderer": "src/renderer/src/App.vue",
    "sharedContract": "src/shared/types.ts"
  },
  "runtimeStorage": {
    "databasePath": "Electron userData/clipmate.db",
    "settingsPath": "Electron userData/settings.json",
    "icloudSyncPath": "~/Library/Mobile Documents/com~apple~CloudDocs/ClipMate/clipmate-history.json"
  },
  "mainCapabilities": [
    "clipboard capture and dedupe",
    "direct paste and plain text paste",
    "search with SQLite FTS fallback",
    "Paste Stack queue",
    "image OCR via Vision helper or Swift fallback",
    "link metadata fetch",
    "iCloud Drive JSON sync",
    "macOS auto update for packaged app"
  ],
  "keyModules": [
    {
      "area": "clipboard",
      "files": [
        "src/main/clipboard/index.ts",
        "src/main/clipboard/watcher.ts",
        "src/main/clipboard/content.ts",
        "src/main/clipboard/io.ts"
      ]
    },
    {
      "area": "database",
      "files": ["src/main/database/index.ts", "src/main/database/clipItems.ts"]
    },
    {
      "area": "windows",
      "files": [
        "src/main/windows/mainWindow.ts",
        "src/main/windows/previewWindow.ts",
        "src/main/windows/settingsWindow.ts",
        "src/main/windows/stackDockWindow.ts"
      ]
    },
    {
      "area": "renderer",
      "files": [
        "src/renderer/src/App.vue",
        "src/renderer/src/panel/MainPanelView.vue",
        "src/renderer/src/panel/usePanelFeed.ts",
        "src/renderer/src/panel/usePanelQueryState.ts",
        "src/renderer/src/panel/usePanelSearchResults.ts",
        "src/renderer/src/panel/usePanelSelection.ts",
        "src/renderer/src/panel/useVirtualCardStrip.ts",
        "src/renderer/src/PreviewView.vue",
        "src/renderer/src/SettingsView.vue",
        "src/renderer/src/StackDockView.vue"
      ]
    },
    {
      "area": "background features",
      "files": [
        "src/main/ocr/worker.ts",
        "src/main/linkMeta/worker.ts",
        "src/main/sync/icloudDrive.ts",
        "src/main/updater/index.ts"
      ]
    }
  ],
  "changeMap": {
    "new_clip_type": [
      "src/shared/types.ts",
      "src/main/clipboard/content.ts",
      "src/main/database/index.ts",
      "src/main/database/clipItems.ts",
      "src/main/clipboard/io.ts",
      "src/renderer/src/panel/MainPanelView.vue",
      "src/renderer/src/PreviewView.vue"
    ],
    "search_or_filters": [
      "src/main/database/clipItems.ts",
      "src/renderer/src/panel/MainPanelView.vue",
      "src/renderer/src/panel/usePanelQueryState.ts",
      "src/renderer/src/panel/usePanelSearchResults.ts"
    ],
    "shortcut_changes": [
      "src/shared/types.ts",
      "src/main/settings/store.ts",
      "src/main/shortcuts.ts",
      "src/renderer/src/SettingsView.vue"
    ],
    "panel_performance": [
      "src/main/index.ts",
      "src/main/panelSnapshot.ts",
      "src/main/events.ts",
      "src/renderer/src/panel/MainPanelView.vue",
      "src/renderer/src/panel/useVirtualCardStrip.ts",
      "src/main/smoke/panelFlow.ts"
    ],
    "release_pipeline": [
      "electron-builder.config.mjs",
      "docs/release.md",
      ".github/workflows/release-mac.yml"
    ]
  },
  "commands": {
    "dev": "npm run dev",
    "typecheck": "npm run typecheck",
    "lint": "npm run lint",
    "build": "npm run build",
    "buildIcons": "npm run build:icons",
    "buildUnpack": "npm run build:unpack",
    "buildMac": "npm run build:mac",
    "panelSmoke": "CLIPMATE_SMOKE_TEST=1 electron-vite preview"
  },
  "verification": {
    "panelSmokeCovers": [
      "main panel open/search/select/live mutation flow",
      "preview edit flows for text/link/color items",
      "image OCR extract actions for copy and create-text-item paths"
    ]
  },
  "docs": {
    "readme": "README.md",
    "prd": "docs/prd.md",
    "todo": "docs/todo.md",
    "release": "docs/release.md",
    "openspecSpecs": "openspec/specs",
    "openspecArchivedChanges": "openspec/changes/archive"
  },
  "importantConstraints": [
    "macOS-only implementation",
    "paste and app switching rely on osascript/open commands",
    "renderer App.vue is now a route shell; main panel coordination lives in src/renderer/src/panel/MainPanelView.vue and src/renderer/src/panel/*",
    "renderer UI icons use @tabler/icons-vue via src/renderer/src/components/UiIcon.vue, while source app icons are still fetched dynamically via system:getAppIcons",
    "app icon and active tray icon assets are generated from build/iconset-source/clipmate.iconset via build/prepare-icons.mjs, while the paused tray icon is a fixed project asset at build/tray/clipmate-tray-paused.png",
    "auto update only works in packaged app",
    "OCR requires packaged helper or local swift toolchain in development"
  ],
  "knownRisks": [
    "limited automated tests",
    "screen share hiding still needs real environment validation",
    "signing/notarization/update flow still depends on real release environment",
    "iCloud sync conflict handling is last-write-wins only"
  ],
  "openspecState": {
    "hasActiveChange": true,
    "note": "An active change exists at openspec/changes/split-main-panel-state-coordinator."
  }
}

---
import SiteFooter from '../components/SiteFooter.astro'
import SiteHeader from '../components/SiteHeader.astro'
import '../styles/global.css'
import { assetHref, siteMeta } from '../config/site'

interface Props {
  title?: string
  description?: string
  currentPath?: string
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  currentPath = '/'
} = Astro.props

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : siteMeta.siteUrl
const pageTitle = title === siteMeta.title ? title : `${title} · ClipMate`
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7faff" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={assetHref('screenshots/main-panel-overview.png')} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={assetHref('icon_512x512@2x.png')} />
    <link rel="apple-touch-icon" href={assetHref('icon_512x512@2x.png')} />
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader currentPath={currentPath} />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
